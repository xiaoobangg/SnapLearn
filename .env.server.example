# ============================================
# SnapLearn 服务器部署环境变量（模板）
# 复制为 .env.server 并填入真实值
#   cp .env.server.example .env.server
# ============================================

# ---- 数据库（宿主机 PostgreSQL） ----
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=snap_learn
DB_USER=postgres
DB_PASSWORD=your-database-password

# ---- 服务端口 ----
BACKEND_PORT=8080
ADMIN_PORT=3001

# ---- JWT 密钥（≥32 字节随机字符串） ----
# 生成命令: openssl rand -hex 32
JWT_SECRET=change-me
JWT_EXPIRE_MINUTES=10080
ADMIN_JWT_SECRET=change-me
ADMIN_JWT_EXPIRE_MINUTES=1440

# ---- LLM（DeepSeek / OpenAI 兼容接口） ----
# 在 https://platform.deepseek.com 获取
LLM_API_KEY=sk-your-deepseek-api-key
LLM_MODEL=deepseek-v4-flash
AI_BASE_URL=https://api.deepseek.com

# ---- 阿里云 DashScope（通义千问 / CosyVoice TTS） ----
# 在 https://bailian.console.aliyun.com 获取
AI_DASHSCOPE_API_KEY=sk-your-dashscope-api-key
DASHSCOPE_WORKSPACE_ID=your-workspace-id

# ---- 百度 OCR ----
# 在 https://console.bce.baidu.com 获取
BAIDU_OCR_API_KEY=your-baidu-ocr-api-key
BAIDU_OCR_SECRET_KEY=your-baidu-ocr-secret-key

# ---- 微信小程序 ----
# 在 https://mp.weixin.qq.com 获取
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# ---- 调试 ----
DEBUG=false
