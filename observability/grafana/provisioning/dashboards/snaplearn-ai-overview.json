{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "选择你的 Prometheus 数据源（snaplearn-prometheus）",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "title": "SnapLearn AI Overview",
  "uid": "snaplearn-ai-overview",
  "tags": ["snaplearn", "ai", "rag"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "model",
        "label": "模型",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "snaplearn-prometheus" },
        "query": "label_values(gen_ai_client_token_usage_total{application=\"snaplearn-backend\"}, gen_ai_request_model)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "累计 Input Token",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "snaplearn-prometheus" },
      "targets": [
        {
          "expr": "sum(gen_ai_client_token_usage_total{application=\"snaplearn-backend\",gen_ai_token_type=\"input\",gen_ai_request_model=~\"$model\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "累计 Output Token",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "snaplearn-prometheus" },
      "targets": [
        {
          "expr": "sum(gen_ai_client_token_usage_total{application=\"snaplearn-backend\",gen_ai_token_type=\"output\",gen_ai_request_model=~\"$model\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "累计调用次数",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "snaplearn-prometheus" },
      "targets": [
        {
          "expr": "sum(gen_ai_client_operation_seconds_count{application=\"snaplearn-backend\",gen_ai_request_model=~\"$model\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "purple" }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "P95 延迟（最近 5 分钟）",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "snaplearn-prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(gen_ai_client_operation_seconds_bucket{application=\"snaplearn-backend\",gen_ai_request_model=~\"$model\"}[5m])) by (le))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Token 消耗速率（每分钟，按模型 + 方向）",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "snaplearn-prometheus" },
      "targets": [
        {
          "expr": "sum(rate(gen_ai_client_token_usage_total{application=\"snaplearn-backend\",gen_ai_request_model=~\"$model\"}[1m])) by (gen_ai_request_model, gen_ai_token_type) * 60",
          "legendFormat": "{{gen_ai_request_model}} / {{gen_ai_token_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "累计 Token 增长曲线",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "snaplearn-prometheus" },
      "targets": [
        {
          "expr": "sum(gen_ai_client_token_usage_total{application=\"snaplearn-backend\",gen_ai_request_model=~\"$model\"}) by (gen_ai_request_model, gen_ai_token_type)",
          "legendFormat": "{{gen_ai_request_model}} / {{gen_ai_token_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "stacking": { "mode": "none" }
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "LLM 调用延迟分位（P50 / P95 / P99）",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "snaplearn-prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(gen_ai_client_operation_seconds_bucket{application=\"snaplearn-backend\",gen_ai_request_model=~\"$model\"}[5m])) by (le, gen_ai_request_model))",
          "legendFormat": "P50 / {{gen_ai_request_model}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(gen_ai_client_operation_seconds_bucket{application=\"snaplearn-backend\",gen_ai_request_model=~\"$model\"}[5m])) by (le, gen_ai_request_model))",
          "legendFormat": "P95 / {{gen_ai_request_model}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(gen_ai_client_operation_seconds_bucket{application=\"snaplearn-backend\",gen_ai_request_model=~\"$model\"}[5m])) by (le, gen_ai_request_model))",
          "legendFormat": "P99 / {{gen_ai_request_model}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 5
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "RAG 流水线 Advisor P95 耗时",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "snaplearn-prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(spring_ai_advisor_seconds_bucket{application=\"snaplearn-backend\"}[5m])) by (le, spring_ai_advisor_name))",
          "legendFormat": "{{spring_ai_advisor_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "HTTP 接口 QPS",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "snaplearn-prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"snaplearn-backend\",uri=~\"/api/v1/.*\"}[1m])) by (uri)",
          "legendFormat": "{{uri}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 5
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "HTTP 错误率（5xx 占比）",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "snaplearn-prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"snaplearn-backend\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_requests_seconds_count{application=\"snaplearn-backend\"}[5m])), 0.001)",
          "legendFormat": "5xx 占比",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    }
  ]
}
